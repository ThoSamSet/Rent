justify-self: stretch;\n            min-width: 0;\n            display: flex;\n            flex-direction: column;\n            height: 100%;\n            min-height: 0;\n            background: white;\n            padding: 0;\n            border-radius: 20px;\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);\n            overflow: hidden;\n        }\n\n        .location-image {\n            flex-shrink: 0;\n            width: 100%;\n            aspect-ratio: 4 / 3;\n            overflow: hidden;\n        }\n\n        .location-image img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            display: block;\n        }\n\n        .location-detail-content {\n            flex: 1;\n            display: flex;\n            flex-direction: column;\n            padding: 28px 32px;\n            min-height: 0;\n        }\n\n        .location-detail h3 {\n            font-weight: 600;\n            margin-bottom: 14px;\n            color: #1d1d1f;\n            display: flex;\n            align-items: center;\n            gap: 12px;\n            flex-wrap: wrap;\n            min-width: 0;\n            overflow-wrap: anywhere;\n        }\n\n        .location-detail-icon {\n        }\n\n        .location-detail p {\n            color: #1d1d1f;\n            line-height: 1.8;\n            margin-bottom: 15px;\n        }\n\n        .location-detail strong {\n            font-weight: 600;\n            color: #1d1d1f;\n        }\n\n        .location-subtitle {\n            color: #86868b;\n            margin: -10px 0 10px 0;\n            overflow-wrap: anywhere;\n        }\n\n        .location-map-link {\n            /* Trong flex column, mặc định con bị stretch full ngang — chỉ bao vừa chữ */\n            align-self: flex-start;\n            width: fit-content;\n            max-width: 100%;\n            display: inline-flex;\n            align-items: center;\n            min-height: 44px;\n            margin-bottom: 12px;\n            padding: 10px 16px;\n            border-radius: 999px;\n            border: 1px solid #d2d2d7;\n            color: #555;\n            text-decoration: none;\n            background: #f9f9fb;\n            transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;\n        }\n\n        .location-map-link:hover {\n            background: #e5f1ff;\n            border-color: #0071e3;\n            color: #0071e3;\n        }\n\n        .location-features {\n            list-style: none;\n            padding: 0;\n            margin: 20px 0;\n        }\n\n        .location-features li {\n            color: #1d1d1f;\n            margin-bottom: 10px;\n            padding-left: 25px;\n            position: relative;\n        }\n\n        .location-features li:before {\n            content: \"✓\";\n            position: absolute;\n            left: 0;\n            color: #0071e3;\n            font-weight: bold;\n        }\n\n        .location-filter-wrap {\n            max-width: var(--page-hero-max-width);\n            margin: 48px auto 0;\n            padding: 0 4px;\n        }\n\n        .location-filter-wrap h2 {\n            font-weight: 600;\n            color: #1d1d1f;\n            margin: 0 0 14px;\n            letter-spacing: -0.02em;\n        }\n\n        #location-filter-status {\n            color: #86868b;\n            margin: 0 0 16px;\n            min-height: 1.4em;\n        }\n\n        .location-filter-buttons {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            align-items: center;\n        }\n\n        .filter-tag-btn {\n            font: inherit;\n            cursor: pointer;\n            min-height: 44px;\n            padding: 10px 18px;\n            border-radius: 999px;\n            border: 1px solid #d2d2d7;\n            color: #1d1d1f;\n            background: #fff;\n            transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;\n        }\n\n        .filter-tag-btn:hover {\n            background: #f9f9fb;\n            border-color: #86868b;\n        }\n\n        .filter-tag-btn:focus-visible {\n            outline: 2px solid #0071e3;\n            outline-offset: 2px;\n        }\n\n        .filter-tag-btn.is-active {\n            background: #e5f1ff;\n            border-color: #0071e3;\n            color: #0071e3;\n            font-weight: 500;\n        }\n\n        .filter-tag-btn.filter-clear {\n            border-style: dashed;\n            color: #555;\n        }\n\n        .location-tags {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 8px;\n            margin: 0 0 14px;\n        }\n\n        .location-tag-chip {\n            display: inline-block;\n            padding: 4px 10px;\n            border-radius: 999px;\n            color: #424245;\n            background: #f5f5f7;\n            border: 1px solid #e8e8ed;\n            line-height: 1.3;\n        }\n\n        .location-detail.location-hidden {\n            display: none;\n        }\n\n        .location-empty-state {\n            display: none;\n            text-align: center;\n            padding: 44px 28px;\n            margin: 20px auto 0;\n            max-width: var(--card-grid-max-width);\n            background: #f5f5f7;\n            border-radius: 16px;\n            border: 1px solid #e8e8ed;\n            color: #1d1d1f;\n        }\n\n        .location-empty-state.is-visible {\n            display: block;\n        }\n\n        .location-empty-state-title {\n            font-weight: 600;\n            margin: 0 0 12px;\n            letter-spacing: -0.015em;\n        }\n\n        .location-empty-state-hint {\n            color: #86868b;\n            margin: 0;\n            line-height: 1.6;\n            max-width: 36em;\n            margin-inline: auto;\n        }\n\n        @media (max-width: 1024px) {\n            .location-info {\n                grid-template-columns: repeat(2, minmax(0, 1fr));\n                max-width: var(--card-grid-max-width);\n            }\n        }\n\n        @media (max-width: 768px) {\n            .locations-hero h1 {\n            }\n\n            .locations-hero p {\n            }\n\n            .map-container {\n                height: 400px;\n                margin: 40px 0;\n            }\n\n            .location-info {\n                grid-template-columns: 1fr;\n                max-width: none;\n                gap: 30px;\n            }\n\n            .location-detail-content {\n                padding: 30px 20px;\n            }\n\n        }\n    </style>"}