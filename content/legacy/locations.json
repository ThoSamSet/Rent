{"content":"<!-- Hero Section -->\n    <section class=\"locations-hero\">\n        <h1>Vị trí Camping</h1>\n        <p><span class=\"no-break\">Camp Nhà Thỏ</span> hỗ trợ đưa đón đến các bãi camping đẹp quanh khu vực Kanto, Nhật Bản</p>\n    </section>\n\n    <!-- Locations Content -->\n    <section class=\"section\">\n        <div class=\"locations-content\">\n            <!-- Map Section -->\n            <div class=\"map-container\">\n                <div id=\"map\"></div>\n            </div>\n\n            <div class=\"location-filter-wrap\">\n                <h2 id=\"location-filter-heading\">Lọc theo</h2>\n                <p id=\"location-filter-status\" aria-live=\"polite\">Hiển thị 15 / 15 bãi</p>\n                <div class=\"location-filter-buttons\" role=\"group\" aria-labelledby=\"location-filter-heading\">\n                    <button type=\"button\" class=\"filter-tag-btn filter-clear is-active\" data-filter-action=\"clear\" aria-pressed=\"true\">Tất cả</button>\n                    <button type=\"button\" class=\"filter-tag-btn\" data-filter-tag=\"view-phu-si\" aria-pressed=\"false\">View Phú Sĩ</button>\n                    <button type=\"button\" class=\"filter-tag-btn\" data-filter-tag=\"gan-ho\" aria-pressed=\"false\">Gần hồ</button>\n                    <button type=\"button\" class=\"filter-tag-btn\" data-filter-tag=\"gan-suoi-song\" aria-pressed=\"false\">Gần suối / sông</button>\n                    <button type=\"button\" class=\"filter-tag-btn\" data-filter-tag=\"gan-bien\" aria-pressed=\"false\">Gần biển</button>\n                    <button type=\"button\" class=\"filter-tag-btn\" data-filter-tag=\"gan-tokyo\" aria-pressed=\"false\">Gần Tokyo</button>\n                    <button type=\"button\" class=\"filter-tag-btn\" data-filter-tag=\"mua-xuan\" aria-pressed=\"false\">Mùa xuân</button>\n                    <button type=\"button\" class=\"filter-tag-btn\" data-filter-tag=\"mua-he\" aria-pressed=\"false\">Mùa hè</button>\n                    <button type=\"button\" class=\"filter-tag-btn\" data-filter-tag=\"mua-thu\" aria-pressed=\"false\">Mùa thu</button>\n                </div>\n            </div>\n\n            <!-- Location Details -->\n            <div class=\"location-info\" id=\"location-info-grid\">\n                <!-- Fumotoppara -->\n                <div class=\"location-detail\" data-site-id=\"fumotoppara\" data-tags=\"view-phu-si mua-xuan mua-he mua-thu\">\n                    <div class=\"location-image\">\n                        <img src=\"/images/location-fumotoppara.jpg\" alt=\"Fumotoppara Camping Ground - View núi Phú Sĩ tuyệt đẹp, bãi cỏ rộng rãi\" loading=\"lazy\" decoding=\"async\">\n                    </div>\n                    <div class=\"location-detail-content\">\n                        <h3>\n                            <span class=\"location-detail-icon\">🏔️</span>\n                            Fumotoppara Camping Ground\n                        </h3>\n                        <p class=\"location-subtitle\">Fumotoppara</p>\n                        <div class=\"location-tags\" aria-label=\"Đặc điểm nổi bật\">\n                            <span class=\"location-tag-chip\">View Phú Sĩ</span>\n                            <span class=\"location-tag-chip\">Mùa xuân</span>\n                            <span class=\"location-tag-chip\">Mùa hè</span>\n                            <span class=\"location-tag-chip\">Mùa thu</span>\n                        </div>\n                        <a href=\"https://www.google.com/maps/place/Fumotoppara+Campground/@35.3994331,138.5622619,17z/data=!4m15!1m5!3m4!2zMzXCsDIzJzU4LjAiTiAxMzjCsDMzJzUzLjQiRQ!8m2!3d35.3994331!4d138.5648368!3m8!1s0x601bddbee949882d:0x282e057b888710f!5m2!4m1!1i2!8m2!3d35.3994199!4d138.5614149!16s%2Fg%2F1wz52srz?entry=ttu&g_ep=EgoyMDI2MDMwOC4wIKXMDSoASAFQAw%3D%3D\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"location-map-link\">Xem trên Google Maps</a>\n                        <p>\n                            Bãi camping với <strong>view núi <span class=\"no-break\">Phú Sĩ</span> tuyệt đẹp</strong>, không gian rộng rãi và yên tĩnh. \n                            Địa điểm lý tưởng để tận hưởng thiên nhiên và ngắm cảnh hoàng hôn, bình minh.\n                        </p>\n                        <ul class=\"location-features\">\n                            <li>View núi <span class=\"no-break\">Phú Sĩ</span> tuyệt đẹp</li>\n                            <li>Bãi cỏ rộng rãi, thoáng đãng</li>\n                            <li>Phù hợp cho nhóm nhỏ và gia đình</li>\n                            <li>Tiện lợi cho chụp ảnh và ngắm cảnh</li>\n                        </ul>\n                    </div>\n                </div>\n\n                <!-- Koan View Phú Sĩ -->\n                <div class=\"location-detail\" data-site-id=\"koan\" data-tags=\"view-phu-si gan-ho mua-xuan mua-he mua-thu\">\n                    <div class=\"location-image\">\n                        <img src=\"/images/location-koan.jpg\" alt=\"Koan Camping Ground Phú Sĩ - View tờ 1000 yên, một trong những địa điểm camping đẹp nhất\" loading=\"lazy\" decoding=\"async\">\n                    </div>\n                    <div class=\"location-detail-content\">\n                        <h3>\n                            <span class=\"location-detail-icon\">⛰️</span>\n                            Koan Camping Ground\n                        </h3>\n                        <p class=\"location-subtitle\">浩庵キャンプ場</p>\n                        <div class=\"location-tags\" aria-label=\"Đặc điểm nổi bật\">\n                            <span class=\"location-tag-chip\">View Phú Sĩ</span>\n                            <span class=\"location-tag-chip\">Gần hồ</span>\n                            <span class=\"location-tag-chip\">Mùa xuân</span>\n                            <span class=\"location-tag-chip\">Mùa hè</span>\n                            <span class=\"location-tag-chip\">Mùa thu</span>\n                        </div>\n                        <a href=\"https://www.google.com/maps/place/Koan+Camping+Ground/@35.4737088,138.5765894,16.06z/data=!4m15!1m5!3m4!2zMzXCsDI4JzIzLjUiTiAxMzjCsDM0JzI5LjIiRQ!8m2!3d35.473183!4d138.574764!3m8!1s0x601be615f5b7e6b9:0x777d79ff931f3ee3!5m2!4m1!1i2!8m2!3d35.473183!4d138.574764!16s%2Fg%2F119vp5061?entry=ttu&g_ep=EgoyMDI2MDMwOC4wIKXMDSoASAFQAw%3D%3D\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"location-map-link\">Xem trên Google Maps</a>\n                        <p>\n                            Địa điểm camping với view tờ 1000 yên nổi tiếng.<br>\n                            Được xem là một trong những địa điểm camping đẹp nhất ở <span class=\"no-break\">Phú Sĩ</span>.\n                        </p>\n                        <ul class=\"location-features\">\n                            <li>Tầm nhìn có hồ và núi</li>\n                            <li>Không gian thoáng đãng</li>\n                            <li>Môi trường trong lành</li>\n                            <li>Phù hợp cho cặp đôi và nhóm nhỏ</li>\n                        </ul>\n                    </div>\n                </div>\n\n                <!-- 朝霧Camp Base そらいろ -->\n                <div class=\"location-detail\" data-site-id=\"asagiri-sorairo\" data-tags=\"view-phu-si mua-xuan mua-he mua-thu\">\n                    <div class=\"location-image\">\n                        <img src=\"/images/location-asagiri-sorairo.jpg\" alt=\"朝霧Camp Base そらいろ - Bãi camping gần Fumotoppara với view Phú Sĩ\" loading=\"lazy\" decoding=\"async\">\n                    </div>\n                    <div class=\"location-detail-content\">\n                        <h3>\n                            <span class=\"location-detail-icon\">🏕️</span>\n                            Asagiri Camp Base Sorairo\n                        </h3>\n                        <p class=\"location-subtitle\">朝霧Camp Base そらいろ</p>\n                        <div class=\"location-tags\" aria-label=\"Đặc điểm nổi bật\">\n                            <span class=\"location-tag-chip\">View Phú Sĩ</span>\n                            <span class=\"location-tag-chip\">Mùa xuân</span>\n                            <span class=\"location-tag-chip\">Mùa hè</span>\n                            <span class=\"location-tag-chip\">Mùa thu</span>\n                        </div>\n                        <a href=\"https://www.google.com/maps/place/%E6%9C%9D%E9%9C%A7Camp+Base+%E3%81%9D%E3%82%89%E3%81%84%E3%82%8D/@35.3925194,138.5599088,15.74z/data=!4m12!1m5!3m4!2zMzXCsDIzJzM2LjUiTiAxMzjCsDMzJzUzLjUiRQ!8m2!3d35.3934589!4d138.5648634!3m5!1s0x601bddc3620f9471:0x6b261f12497aa1ee!8m2!3d35.3934589!4d138.5648634!16s%2Fg%2F11t_r64wmn?entry=ttu&g_ep=EgoyMDI2MDMwOC4wIKXMDSoASAFQAw%3D%3D\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"location-map-link\">Xem trên Google Maps</a>\n                        <p>\n                            Bãi camping 朝霧Camp Base そらいろ nằm gần khu vực Fumotoppara,<br>\n                            phù hợp cho những bạn muốn trải nghiệm không khí camping ở vùng chân núi <span class=\"no-break\">Phú Sĩ</span>.\n                        </p>\n                        <ul class=\"location-features\">\n                            <li>Gần khu vực Fumotoppara</li>\n                            <li>Không gian thoáng, gần thiên nhiên</li>\n                            <li>Phù hợp cho nhóm nhỏ và gia đình</li>\n                        </ul>\n                    </div>\n                </div>\n\n                <!-- Fujisan Wild Adventure -->\n                <div class=\"location-detail\" data-site-id=\"fujisan-wild\" data-tags=\"view-phu-si mua-xuan mua-he mua-thu\">\n                    <div class=\"location-image\">\n                        <img src=\"/images/location-fujisan-wild-adventure.jpg\" alt=\"Fujisan Wild Adventure - Khu camping và hoạt động ngoài trời gần núi Phú Sĩ\" loading=\"lazy\" decoding=\"async\">\n                    </div>\n                    <div class=\"location-detail-content\">\n                        <h3>\n                            <span class=\"location-detail-icon\">🏕️</span>\n                            Fujisan Wild Adventure\n                        </h3>\n                        <p class=\"location-subtitle\">富士山ワイルドアドベンチャー</p>\n                        <div class=\"location-tags\" aria-label=\"Đặc điểm nổi bật\">\n                            <span class=\"location-tag-chip\">View Phú Sĩ</span>\n                            <span class=\"location-tag-chip\">Mùa xuân</span>\n                            <span class=\"location-tag-chip\">Mùa hè</span>\n                            <span class=\"location-tag-chip\">Mùa thu</span>\n                        </div>\n                        <a href=\"https://www.google.com/maps/place/Fujisan+Wild+Adventure/@35.3302986,138.6143224,17z/data=!3m1!4b1!4m9!3m8!1s0x601bdb1ad33feedb:0xb6a32ab837014576!5m2!4m1!1i2!8m2!3d35.3302986!4d138.6168973!16s%2Fg%2F11f7r2s0c2?entry=ttu&g_ep=EgoyMDI2MDMwOC4wIKXMDSoASAFQAw%3D%3D\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"location-map-link\">Xem trên Google Maps</a>\n                        <p>\n                            Fujisan Wild Adventure là khu vực camping và trải nghiệm ngoài trời nằm gần chân núi <span class=\"no-break\">Phú Sĩ</span>,<br>\n                            phù hợp cho những bạn thích hoạt động, không khí hoang dã và muốn thử nhiều trải nghiệm khác nhau.\n                        </p>\n                        <ul class=\"location-features\">\n                            <li>Gần khu vực núi <span class=\"no-break\">Phú Sĩ</span></li>\n                            <li>Nhiều hoạt động và trải nghiệm ngoài trời</li>\n                            <li>Phù hợp cho nhóm bạn thích khám phá</li>\n                        </ul>\n                    </div>\n                </div>\n\n                <!-- Fujiminooka Auto Camping Ground -->\n                <div class=\"location-detail\" data-site-id=\"fujiminooka\" data-tags=\"view-phu-si mua-xuan mua-he mua-thu\">\n                    <div class=\"location-image\">\n                        <img src=\"/images/location-fujiminooka.jpg\" alt=\"Fujiminooka Auto Camping Ground - Bãi camping với không gian rộng và view núi Phú Sĩ\" loading=\"lazy\" decoding=\"async\">\n                    </div>\n                    <div class=\"location-detail-content\">\n                        <h3>\n                            <span class=\"location-detail-icon\">🏕️</span>\n                            Fujiminooka Auto Camping Ground\n                        </h3>\n                        <p class=\"location-subtitle\">富士見の丘オートキャンプ場</p>\n                        <div class=\"location-tags\" aria-label=\"Đặc điểm nổi bật\">\n                            <span class=\"location-tag-chip\">View Phú Sĩ</span>\n                            <span class=\"location-tag-chip\">Mùa xuân</span>\n                            <span class=\"location-tag-chip\">Mùa hè</span>\n                            <span class=\"location-tag-chip\">Mùa thu</span>\n                        </div>\n                        <a href=\"https://www.google.com/maps/place/Fujiminooka+Auto+Camping+Ground/@35.2179438,138.6999732,17z/data=!3m1!4b1!4m9!3m8!1s0x601bd5749e08b1d1:0xe680720c4d3b36b0!5m2!4m1!1i2!8m2!3d35.2179438!4d138.7025481!16s%2Fg%2F11qpswg4_h?entry=ttu&g_ep=EgoyMDI2MDMwOC4wIKXMDSoASAFQAw%3D%3D\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"location-map-link\">Xem trên Google Maps</a>\n                        <p>\n                            Fujiminooka Auto Camping Ground là bãi camping với không gian rộng rãi,<br>\n                            có thể nhìn về khu vực núi <span class=\"no-break\">Phú Sĩ</span> và phù hợp cho cả nhóm bạn lẫn gia đình.\n                        </p>\n                        <ul class=\"location-features\">\n                            <li>Dễ bố trí nhiều lều</li>\n                            <li>Khu vực gần núi <span class=\"no-break\">Phú Sĩ</span></li>\n                            <li>Phù hợp cho nhóm bạn và gia đình</li>\n                        </ul>\n                    </div>\n                </div>\n\n                <!-- Lake Tanuki / Tanukiko Camp Ground -->\n                <div class=\"location-detail\" data-site-id=\"tanukiko\" data-tags=\"gan-ho view-phu-si mua-he mua-thu\">\n                    <div class=\"location-image\">\n                        <img src=\"/images/location-tanukiko.jpg\" alt=\"田貫湖キャンプ場 Lake Tanuki – bãi camping ven hồ gần núi Phú Sĩ\" loading=\"lazy\" decoding=\"async\">\n                    </div>\n                    <div class=\"location-detail-content\">\n                        <h3>\n                            <span class=\"location-detail-icon\">🏕️</span>\n                            Lake Tanuki Camp Ground\n                        </h3>\n                        <p class=\"location-subtitle\">田貫湖キャンプ場</p>\n                        <div class=\"location-tags\" aria-label=\"Đặc điểm nổi bật\">\n                            <span class=\"location-tag-chip\">Gần hồ</span>\n                            <span class=\"location-tag-chip\">View Phú Sĩ</span>\n                            <span class=\"location-tag-chip\">Mùa hè</span>\n                            <span class=\"location-tag-chip\">Mùa thu</span>\n                        </div>\n                        <a href=\"https://www.google.com/maps/place/%E7%94%B0%E8%B2%AB%E6%B9%96%E3%82%AD%E3%83%A3%E3%83%B3%E3%83%97%E5%A0%B4/@35.3419124,138.5589793,17z/data=!4m9!3m8!1s0x601bc352cee2b731:0x59891a3a0578c4b9!5m2!4m1!1i2!8m2!3d35.3419124!4d138.5615542!16s%2Fg%2F119tgvpdj?authuser=0&amp;entry=ttu&amp;g_ep=EgoyMDI2MDUwMi4wIKXMDSoASAFQAw%3D%3D\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"location-map-link\">Xem trên Google Maps</a>\n                        <p>\n                            Bãi camping ven hồ Tanuki (<span lang=\"ja\">田貫湖</span>), khu vực chân núi <span class=\"no-break\">Phú Sĩ</span> — không gian hồ nước dễ chịu, thường được yêu thích vào <strong>mùa hè</strong> và khi lá đổi màu <strong>mùa thu</strong>.\n                        </p>\n                        <ul class=\"location-features\">\n                            <li>Gần hồ, không khí mát và trong lành</li>\n                            <li>Có góc ngắm núi <span class=\"no-break\">Phú Sĩ</span> đặc trưng vùng hồ</li>\n                            <li>Phù hợp nghỉ cuối tuần, nhóm nhỏ và gia đình</li>\n                        </ul>\n                    </div>\n                </div>\n\n                <!-- Aone Camping Ground -->\n                <div class=\"location-detail\" data-site-id=\"aone\" data-tags=\"gan-suoi-song gan-tokyo mua-he\">\n                    <div class=\"location-image\">\n                        <img src=\"/images/location-aone.jpg\" alt=\"Aone Camping Ground 青根キャンプ場 - Bãi camping gần Tokyo, gần suối\" loading=\"lazy\" decoding=\"async\">\n                    </div>\n                    <div class=\"location-detail-content\">\n                        <h3>\n                            <span class=\"location-detail-icon\">🏕️</span>\n                            Aone Camping Ground\n                        </h3>\n                        <p class=\"location-subtitle\">青根キャンプ場</p>\n                        <div class=\"location-tags\" aria-label=\"Đặc điểm nổi bật\">\n                            <span class=\"location-tag-chip\">Gần suối / sông</span>\n                            <span class=\"location-tag-chip\">Gần Tokyo</span>\n                            <span class=\"location-tag-chip\">Mùa hè</span>\n                        </div>\n                        <a href=\"https://www.google.com/maps/place/Aone+Camping+Ground/@35.5477275,139.1334992,757m/data=!3m2!1e3!4b1!4m9!3m8!1s0x60191173cd9b29a5:0x85bf5a24c8d72634!5m2!4m1!1i2!8m2!3d35.5477275!4d139.1360741!16s%2Fg%2F119v9_tw6?entry=ttu&g_ep=EgoyMDI2MDMzMC4wIKXMDSoASAFQAw%3D%3D\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"location-map-link\">Xem trên Google Maps</a>\n                        <p>\n                            Aone Camping Ground là bãi camping gần Tokyo, phù hợp cho chuyến đi ngắn cuối tuần.<br>\n                            Khu vực gần suối, không khí mát mẻ vào mùa hè.\n                        </p>\n                        <ul class=\"location-features\">\n                            <li>Gần Tokyo, tiện di chuyển</li>\n                            <li>Gần suối, phù hợp vui chơi mùa hè</li>\n                            <li>Phù hợp cho nhóm bạn và gia đình</li>\n                        </ul>\n                    </div>\n                </div>\n\n                <!-- Nagatoro Auto Campground -->\n                <div class=\"location-detail\" data-site-id=\"nagatoro\" data-tags=\"gan-suoi-song mua-he mua-xuan\">\n                    <div class=\"location-image\">\n                        <img src=\"/images/location-nagatoro-auto-campground.jpg\" alt=\"Nagatoro Auto Campground 長瀞オートキャンプ場\" loading=\"lazy\" decoding=\"async\">\n                    </div>\n                    <div class=\"location-detail-content\">\n                        <h3>\n                            <span class=\"location-detail-icon\">🏕️</span>\n                            Nagatoro Auto Campground\n                        </h3>\n                        <p class=\"location-subtitle\">長瀞オートキャンプ場</p>\n                        <div class=\"location-tags\" aria-label=\"Đặc điểm nổi bật\">\n                            <span class=\"location-tag-chip\">Gần suối / sông</span>\n                            <span class=\"location-tag-chip\">Mùa xuân</span>\n                            <span class=\"location-tag-chip\">Mùa hè</span>\n                        </div>\n                        <a href=\"https://www.google.com/maps/place/Nagatoro+auto+campground/@36.0393107,139.0539701,12.06z/data=!4m9!3m8!1s0x601ec67066ae0a91:0xa13a869ba05b507!5m2!4m1!1i2!8m2!3d36.105016!4d139.114251!16s%2Fg%2F1tr17ngq?authuser=1&entry=ttu&g_ep=EgoyMDI2MDMwOC4wIKXMDSoASAFQAw%3D%3D\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"location-map-link\">Xem trên Google Maps</a>\n                        <p>\n                            Nagatoro Auto Campground là bãi camping ven sông tại Saitama,<br>\n                            phù hợp cho nhóm bạn và gia đình muốn kết hợp hoạt động ngoài trời và nghỉ ngơi thư giãn.\n                        </p>\n                        <ul class=\"location-features\">\n                            <li>Vị trí ven sông, không khí mát mẻ</li>\n                            <li>Nằm trong khu vực Saitama, tiện di chuyển từ Kanto</li>\n                            <li>Phù hợp cho nhóm bạn và gia đình</li>\n                        </ul>\n                    </div>\n                </div>\n\n                <!-- Tanoue Camping Ground -->\n                <div class=\"location-detail\" data-site-id=\"tanoue\" data-tags=\"gan-bien mua-he mua-xuan\">\n                    <div class=\"location-image\">\n                        <img src=\"/images/location-tanoue.jpg\" alt=\"Tanoue Camping Ground 田の上キャンプ場\" loading=\"lazy\" decoding=\"async\">\n                    </div>\n                    <div class=\"location-detail-content\">\n                        <h3>\n                            <span class=\"location-detail-icon\">🏕️</span>\n                            Tanoue Camping Ground\n                        </h3>\n                        <p class=\"location-subtitle\">田の上キャンプ場</p>\n                        <div class=\"location-tags\" aria-label=\"Đặc điểm nổi bật\">\n                            <span class=\"location-tag-chip\">Gần biển</span>\n                            <span class=\"location-tag-chip\">Mùa xuân</span>\n                            <span class=\"location-tag-chip\">Mùa hè</span>\n                        </div>\n                        <a href=\"https://www.google.com/maps/place/Tanoue+Camping+Ground/@36.392397,140.6094091,17z/data=!3m1!4b1!4m6!3m5!1s0x60222df41df36d75:0xc0232f844cc039e!8m2!3d36.392397!4d1